MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/supplyconnect?retryWrites=true&w=majority
MONGODB_DB_NAME=supplyconnect
JWT_SECRET=replace-with-a-strong-secret
PORT=10000

# Optional alternative to MONGODB_URI on platforms like Render:
# MONGODB_USERNAME=your-db-user
# MONGODB_PASSWORD=your-db-password
# MONGODB_HOST=cluster.mongodb.net
